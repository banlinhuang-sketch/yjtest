{
  "name": "yijing-test-department",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:all": "node scripts/dev-all.mjs",
    "api": "node server/index.mjs",
    "health:local": "node scripts/local-health.mjs",
    "health:ops": "node scripts/ops-health.mjs",
    "smoke:api": "node scripts/api-smoke.mjs",
    "smoke:formal": "node scripts/formal-backend-smoke.mjs",
    "backup:sqlite": "node scripts/sqlite-backup.mjs",
    "db:report": "node scripts/db-schema-report.mjs",
    "db:export-snapshot": "node scripts/sqlite-export-snapshot.mjs",
    "cleanup:exports": "node scripts/export-cleanup.mjs",
    "playwright:install": "playwright install chromium",
    "test:browser": "playwright test",
    "test:browser:headed": "playwright test --headed",
    "test:browser:formal": "playwright test --config playwright.formal.config.ts",
    "test:browser:formal:headed": "playwright test --config playwright.formal.config.ts --headed",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
